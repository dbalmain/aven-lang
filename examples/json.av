# Json.decode with optional/nullable fields, ?> error handling, value.encode(Json) round-trip.
# text.decode(Json, User) is the dataflow-order spelling of Json.decode(text, User).
User = { name: Text, email: ?Text, nick: Text? }

parseUser = (text: Text) =>
  user = text.decode(Json, User)?^
  @Ok(user)

onParsed = (user) =>
  writeLine("parsed: ${user}")
  encoded = user.encode(Json)
  writeLine("encoded: ${encoded}")

onError = (err) => writeLine("error: ${err}")

parsed = parseUser("{\"name\":\"Ada\",\"nick\":null}")
parsed ?>
  @Ok(user) => onParsed(user)
  @Err(err) => onError(err)
