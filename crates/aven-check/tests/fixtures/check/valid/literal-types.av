Status = @{"waiting", "running"}
Waiting = @{"waiting"}
Codes = @{0, 1, 2}
ZeroOne = @{0, 1}

status : Status = "waiting"
code : Codes = 1
mode : "r" | "w" | "rw" = "r"
variant : @A | @B = @A

waiting : Waiting = "waiting"
wideStatus : Status = waiting

zeroOne : ZeroOne = 0
wideCode : Codes = zeroOne
